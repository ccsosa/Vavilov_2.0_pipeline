file_DMR <- file_DMR[, c(1:4, 11:12)]
setDT(file_DMR)
# Totales de DMRs antes de cualquier overlap
total_dmrs_file <- unique(file_DMR, by = c("seqnames", "start", "end"))[, .(
n_DMRs       = .N,
total_bp_DMR = sum(as.numeric(end - start + 1))
), by = Status]
total_dmrs_file[, file := files[h]]
dmr_totals_all[[h]] <- total_dmrs_file
# Overlap contra cada feature
for(feat_name in names(feature_list)) {
cat("  Feature:", feat_name, "\n")
res <- run_overlap(file_DMR, feature_list[[feat_name]], chromosomes)
if(!is.null(res)) {
res[, file := files[h]]
overlaps_by_feature[[feat_name]][[h]] <- res
}
}
}
# Consolidar por feature
final_results <- lapply(overlaps_by_feature, function(x) {
if(length(x) > 0) rbindlist(x, fill = TRUE) else NULL
})
# Renombrar archivos
for(feat_name in names(final_results)) {
if(is.null(final_results[[feat_name]])) next
for(i in seq_along(files)) {
final_results[[feat_name]]$file[final_results[[feat_name]]$file == files[i]] <- replace_fi[i]
}
}
# Guardar overlaps detallados
fwrite(final_results$TEs,      "D:/JJG_OCT25/RESULTS_MET/file_DMR_overlap_repeats.csv")
fwrite(final_results$Upstream, "D:/JJG_OCT25/RESULTS_MET/file_DMR_overlap_Upstream.csv")
fwrite(final_results$Genebody, "D:/JJG_OCT25/RESULTS_MET/file_DMR_overlap_GENES.csv")
# ============================================================
# 6. ENRIQUECIMIENTO — Chi-square por feature
# ============================================================
dmr_totals <- rbindlist(dmr_totals_all, fill = TRUE)
dmr_totals[, file_label := replace_fi[match(file, files)]]
all_enrich <- list()
for(feat_name in names(feature_list)) {
feat_bp      <- feature_bp[[feat_name]]
final_result <- final_results[[feat_name]]
if(is.null(final_result)) next
# bp exactas de DMRs en esta feature (agrupado por DMR para evitar duplicar bp)
dmr_in_feat <- final_result[, .(
bp_in_feat_dmr = sum(overlap_bp)
), by = .(file, Status, seqnames, start, end)][, .(
n_in_feat  = .N,
bp_in_feat = sum(as.numeric(bp_in_feat_dmr))
), by = .(file, Status)]
enrich_results <- list()
for(i in seq_along(replace_fi)) {
fi  <- replace_fi[i]
tot <- dmr_totals[file_label == fi]
for(st in c("hyper", "hypo")) {
bp_total_status <- tot[Status == st, total_bp_DMR]
n_total_status  <- tot[Status == st, n_DMRs]
if(length(bp_total_status) == 0 || bp_total_status == 0) next
bp_in_feat_val <- dmr_in_feat[file == fi & Status == st, bp_in_feat]
if(length(bp_in_feat_val) == 0) bp_in_feat_val <- 0
bp_out_feat      <- bp_total_status - bp_in_feat_val
nonDMR_feat_bp   <- feat_bp - bp_in_feat_val
nonDMR_nonfeat_bp <- (total_bp - feat_bp) - bp_out_feat
mat <- matrix(
c(bp_in_feat_val,    bp_out_feat,
nonDMR_feat_bp,    nonDMR_nonfeat_bp),
nrow = 2,
dimnames = list(c("In_feat", "Not_in_feat"), c("DMR", "Background"))
)
ct        <- chisq.test(mat, correct = FALSE)
fe        <- (bp_in_feat_val / bp_total_status) / (feat_bp / total_bp)
cramers_v <- sqrt(ct$statistic / sum(as.numeric(mat)))
p_val_safe <- ifelse(ct$p.value == 0, .Machine$double.eps, ct$p.value)
enrich_results[[paste(fi, st, sep = "_")]] <- data.table(
feature           = feat_name,
file              = fi,
status            = st,
n_DMR_total       = n_total_status,
bp_DMR_total      = bp_total_status,
bp_DMR_in_feat    = bp_in_feat_val,
bp_DMR_out_feat   = bp_out_feat,
bp_feat_free      = nonDMR_feat_bp,
bp_nonfeat_free   = nonDMR_nonfeat_bp,
check_row_DMR     = bp_in_feat_val + bp_out_feat,
check_row_BG      = nonDMR_feat_bp + nonDMR_nonfeat_bp,
check_col_feat    = bp_in_feat_val + nonDMR_feat_bp,
check_total       = bp_in_feat_val + bp_out_feat + nonDMR_feat_bp + nonDMR_nonfeat_bp,
check_negative    = any(c(bp_in_feat_val, bp_out_feat, nonDMR_feat_bp, nonDMR_nonfeat_bp) < 0),
pct_DMR_in_feat   = round(bp_in_feat_val / bp_total_status * 100, 2),
pct_genome_feat   = round(feat_bp / total_bp * 100, 2),
fold_enrichment   = round(fe, 3),
chi_square        = round(ct$statistic, 4),
cramers_v         = round(cramers_v, 6),
p_value           = p_val_safe,
direction         = ifelse(fe > 1, "enriched", "depleted")
)
}
}
all_enrich[[feat_name]] <- rbindlist(enrich_results)
}
# Consolidar todas las features
# Consolidar todas las features
# Consolidar todas las features
enrichment_table <- rbindlist(all_enrich)
# p_adj_BH independiente por feature (12 tests cada una)
enrichment_table[, p_adj_BH := p.adjust(p_value, method = "fdr"), by = feature]
enrichment_table[, significant := p_adj_BH < 0.05]
enrichment_table[, enriched    := direction == "enriched" & significant == TRUE]
print(enrichment_table)
# Archivo combinado
fwrite(enrichment_table, "D:/JJG_OCT25/RESULTS_MET/enrichment_ChiSquare_allFeatures.csv")
# Archivos separados por feature
for(feat_name in names(all_enrich)) {
fwrite(
enrichment_table[feature == feat_name],
paste0("D:/JJG_OCT25/RESULTS_MET/enrichment_ChiSquare_", feat_name, ".csv")
)
}
library(data.table)
library(Biostrings)
# ============================================================
# 1. BACKGROUND GENÓMICO
# ============================================================
dna_seqs <- readDNAStringSet("D:/JJG_OCT25/Data/Genomic_features_sativa/IRGSP-1.0_genome.fasta")
total_bp <- sum(as.numeric(width(dna_seqs)))
# ============================================================
# 2. CARGAR FEATURES GENÓMICAS
# ============================================================
repeats_feat <- fread("D:/JJG_OCT25/Data/Genomic_features_sativa/repeats.csv");  setDT(repeats_feat)
upstream_feat <- fread("D:/JJG_OCT25/Data/Genomic_features_sativa/upstream.csv"); setDT(upstream_feat)
genes_feat    <- fread("D:/JJG_OCT25/Data/Genomic_features_sativa/genes.csv");    setDT(genes_feat)
feature_list <- list(
TEs       = repeats_feat,
Upstream  = upstream_feat,
Genebody  = genes_feat
)
feature_bp <- sapply(feature_list, function(f) {
sum(as.numeric(f$End - f$Start + 1))
})
cat("Background bp por feature:\n")
print(feature_bp)
cat("Total genoma bp:", total_bp, "\n")
# ============================================================
# 3. CONFIGURACIÓN DE ARCHIVOS DMR
# ============================================================
inDir <- "D:/JJG_OCT25/Data/Epigenome/DMRs_annotated"
files <- c("AZU_CG_AC_AT", "AZU_CHG_AC_AT", "AZU_CHH_AC_AT",
"BGI_CG_BC_BT", "BGI_CHG_BC_BT", "BGI_CHH_BC_BT")
replace_fi <- c("Azucena (CG context)", "Azucena (CHG context)", "Azucena (CHH context)",
"BGI (CG context)",     "BGI (CHG context)",     "BGI (CHH context)")
chromosomes <- paste0("chr", sprintf("%02d", 1:12))
# ============================================================
# 4. FUNCIÓN DE OVERLAP NUCLEÓTIDO A NUCLEÓTIDO
# ============================================================
run_overlap <- function(file_DMR, feature_dt, chromosomes) {
all_overlaps <- list()
for(i in seq_along(chromosomes)) {
feat_chr <- feature_dt[Chromosome == chromosomes[i]]
dmr_chr  <- file_DMR[seqnames == chromosomes[i]]
if(nrow(feat_chr) == 0 || nrow(dmr_chr) == 0) next
setkey(feat_chr, Start, End)
setkey(dmr_chr, start, end)
overlaps <- foverlaps(
dmr_chr, feat_chr,
by.x = c("start", "end"),
by.y = c("Start", "End"),
type = "any", nomatch = NULL
)
if(nrow(overlaps) > 0) {
overlaps[, overlap_start := pmax(start, Start)]
overlaps[, overlap_end   := pmin(end,   End)]
overlaps[, overlap_bp    := pmax(0, overlap_end - overlap_start + 1)]
overlaps <- overlaps[overlap_bp > 0]
if(nrow(overlaps) > 0) {
overlaps[, feat_id  := ID_gene]
overlaps[, overlap  := TRUE]
all_overlaps[[i]] <- overlaps
}
}
}
if(length(all_overlaps) > 0) rbindlist(all_overlaps, fill = TRUE) else NULL
}
# ============================================================
# 5. LOOP PRINCIPAL — DMR TOTALS + OVERLAP POR FEATURE
# ============================================================
dmr_totals_all     <- list()
overlaps_by_feature <- list(TEs = list(), Upstream = list(), Genebody = list())
for(h in seq_along(files)) {
cat("\nProcessing:", files[h], "\n")
file_DMR <- fread(paste0(inDir, "/", files[h], "_StateCalls-filtered.txt_Annotated"))
file_DMR <- file_DMR[, c(1:4, 11:12)]
setDT(file_DMR)
# Totales de DMRs antes de cualquier overlap
total_dmrs_file <- unique(file_DMR, by = c("seqnames", "start", "end"))[, .(
n_DMRs       = .N,
total_bp_DMR = sum(as.numeric(end - start + 1))
), by = Status]
total_dmrs_file[, file := files[h]]
dmr_totals_all[[h]] <- total_dmrs_file
# Overlap contra cada feature
for(feat_name in names(feature_list)) {
cat("  Feature:", feat_name, "\n")
res <- run_overlap(file_DMR, feature_list[[feat_name]], chromosomes)
if(!is.null(res)) {
res[, file := files[h]]
overlaps_by_feature[[feat_name]][[h]] <- res
}
}
}
# Consolidar por feature
final_results <- lapply(overlaps_by_feature, function(x) {
if(length(x) > 0) rbindlist(x, fill = TRUE) else NULL
})
# Renombrar archivos
for(feat_name in names(final_results)) {
if(is.null(final_results[[feat_name]])) next
for(i in seq_along(files)) {
final_results[[feat_name]]$file[final_results[[feat_name]]$file == files[i]] <- replace_fi[i]
}
}
# Guardar overlaps detallados
fwrite(final_results$TEs,      "D:/JJG_OCT25/RESULTS_MET/file_DMR_overlap_repeats.csv")
fwrite(final_results$Upstream, "D:/JJG_OCT25/RESULTS_MET/file_DMR_overlap_Upstream.csv")
fwrite(final_results$Genebody, "D:/JJG_OCT25/RESULTS_MET/file_DMR_overlap_GENES.csv")
# ============================================================
# 6. ENRIQUECIMIENTO — Chi-square por feature
# ============================================================
dmr_totals <- rbindlist(dmr_totals_all, fill = TRUE)
dmr_totals[, file_label := replace_fi[match(file, files)]]
all_enrich <- list()
for(feat_name in names(feature_list)) {
feat_bp      <- feature_bp[[feat_name]]
final_result <- final_results[[feat_name]]
if(is.null(final_result)) next
# bp exactas de DMRs en esta feature (agrupado por DMR para evitar duplicar bp)
dmr_in_feat <- final_result[, .(
bp_in_feat_dmr = sum(overlap_bp)
), by = .(file, Status, seqnames, start, end)][, .(
n_in_feat  = .N,
bp_in_feat = sum(as.numeric(bp_in_feat_dmr))
), by = .(file, Status)]
